<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="BDD Cucumber Suite" parallel="tests" thread-count="4">
    <listeners>
        <listener class-name="com.bddcucumberframework.listener.ExtentTestNGListener"/>
        <listener class-name="org.testng.reporters.XMLReporter"/>
        <listener class-name="org.testng.reporters.EmailableReporter2"/>
    </listeners>

    <test name="Cucumber Tests">
        <classes>
            <class name="com.bddcucumberframework.runner.TestRunner"/>
        </classes>
    </test>
</suite>
